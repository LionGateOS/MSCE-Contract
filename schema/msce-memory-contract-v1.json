{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MSCE Memory Contract v1",
  "version": "1.0.0",
  "type": "object",
  "required": [
    "contract_version",
    "event_id",
    "timestamp",
    "source_system",
    "generated_by",
    "project",
    "task_id",
    "task_type",
    "lifecycle_state",
    "summary",
    "confidence",
    "provenance"
  ],
  "properties": {
    "contract_version": {
      "type": "string",
      "const": "msce-memory-contract-v1"
    },
    "event_id": {
      "type": "string"
    },
    "timestamp": {
      "type": "string"
    },
    "source_system": {
      "type": "string"
    },
    "generated_by": {
      "type": "string"
    },
    "project": {
      "type": "string"
    },
    "task_id": {
      "type": "string"
    },
    "task_type": {
      "type": "string"
    },
    "lifecycle_state": {
      "type": "string",
      "enum": [
        "planned",
        "running",
        "completed",
        "failed",
        "blocked",
        "awaiting_approval",
        "cancelled",
        "unknown"
      ]
    },
    "summary": {
      "type": "string"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "decisions_detected": {
      "type": "array"
    },
    "outcomes_detected": {
      "type": "array"
    },
    "blockers_detected": {
      "type": "array"
    },
    "validation_results": {
      "type": "array"
    },
    "evidence": {
      "type": "array"
    },
    "related_events": {
      "type": "array"
    },
    "continuity_signals": {
      "type": "array"
    },
    "provenance": {
      "type": "object",
      "required": [
        "originating_system",
        "source_event_references",
        "interpretation_version"
      ],
      "properties": {
        "originating_system": {
          "type": "string"
        },
        "source_event_references": {
          "type": "array"
        },
        "interpretation_version": {
          "type": "string"
        }
      }
    }
  }
}
